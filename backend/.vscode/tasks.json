{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install Backend Dependencies",
			"type": "shell",
			"command": "pip"
		},
		{
			"label": "Install Backend Dependencies",
			"type": "shell",
			"command": "pip",
			"args": [
				"install",
				"-r",
				"requirements.txt"
			]
		},
		{
			"label": "Run Backend Server",
			"type": "shell",
			"command": "python",
			"args": [
				"app.py"
			],
			"isBackground": true
		}
	]
}